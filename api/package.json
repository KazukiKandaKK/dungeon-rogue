{
  "name": "roguelike-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":       "node --import tsx/esm src/index.ts",
    "start":     "node dist/index.js",
    "build":     "tsc",
    "test":      "vitest run",
    "test:watch":"vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono":              "^4.7.10"
  },
  "devDependencies": {
    "@types/node":  "^22.15.17",
    "tsx":          "^4.19.4",
    "typescript":   "^5.8.3",
    "vitest":       "^1.6.1"
  },
  "optionalDependencies": {
    "better-sqlite3":    "^11.10.0",
    "@types/better-sqlite3": "^7.6.12"
  }
}
