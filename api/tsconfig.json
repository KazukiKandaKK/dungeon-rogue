{
  "compilerOptions": {
    "target":           "ES2022",
    "lib":              ["ES2022"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "strict":           true,
    "noEmit":           false,
    "outDir":           "dist",
    "rootDir":          "src",
    "skipLibCheck":     true,
    "sourceMap":        true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
